menu "Watch WiFi / SNTP (roadmap 1.3)"

    config WATCH_WIFI_STA_ENABLE
        bool "Enable WiFi STA + SNTP, write PCF85063"
        default y
        help
            When SSID is non-empty: init netif, connect STA, run SNTP, on success write Asia/Shanghai wall time to RTC.
            Password may be empty for open AP.

    config WATCH_WIFI_STA_SSID
        string "Wi-Fi SSID"
        depends on WATCH_WIFI_STA_ENABLE
        default ""
        help
            Leave empty to skip WiFi/SNTP at boot (no connect).

    config WATCH_WIFI_STA_PASSWORD
        string "Wi-Fi password"
        depends on WATCH_WIFI_STA_ENABLE
        default ""

endmenu

menu "Watch display power (roadmap 1.5)"

    config WATCH_DISPLAY_IDLE_TIMEOUT_SEC
        int "Blank display after idle seconds (0 = off)"
        range 0 3600
        default 30
        help
            Uses LVGL pointer inactivity (last PRESS). After this many idle seconds,
            panel DISPOFF via bsp_lcd; next touch wakes (DISPON + full scr invalidate).

endmenu
